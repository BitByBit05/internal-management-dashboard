<%- include('../partials/header') %>

<a href="/books" class="btn btn-secondary" style="margin-bottom:1.5rem;display:inline-block;">← Back</a>
<h1><%= book ? 'Edit Book' : 'Add New Book' %></h1>

<form action="<%= action %>" method="<%= method %>" style="max-width:520px;">
  <div class="form-group">
    <label for="title">Title</label>
    <input
      id="title" name="title" type="text" required
      value="<%= book ? book.title : '' %>"
      placeholder="e.g. The Pragmatic Programmer"
    />
  </div>

  <div class="form-group">
    <label for="author">Author</label>
    <input
      id="author" name="author" type="text" required
      value="<%= book ? book.author : '' %>"
      placeholder="e.g. Andy Hunt"
    />
  </div>

  <div class="form-group">
    <label for="genre">Genre</label>
    <select id="genre" name="genre">
      <% const genres = ['Fiction','Non-Fiction','Science','Technology','History','Biography','Fantasy','Mystery','Romance','Other']; %>
      <option value="">— Select —</option>
      <% genres.forEach(g => { %>
        <option value="<%= g %>" <%= (book && book.genre === g) ? 'selected' : '' %>>
          <%= g %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label for="published_year">Published Year</label>
    <input
      id="published_year" name="published_year" type="number"
      min="1000" max="<%= new Date().getFullYear() %>"
      value="<%= book ? book.published_year : '' %>"
      placeholder="e.g. 1999"
    />
  </div>

  <button class="btn btn-primary" type="submit" style="margin-top:0.5rem;">
    <%= book ? 'Save Changes' : 'Add Book' %>
  </button>
</form>

<%- include('../partials/footer') %>
